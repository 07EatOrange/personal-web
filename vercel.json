{
  "rewrites": [
    { "source": "/((?!assets/|favicon\\.svg|avatar\\.jpg|.*\\.js|.*\\.css|.*\\.map|.*\\.png|.*\\.jpg|.*\\.svg|.*\\.ico|.*\\.woff2?).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
